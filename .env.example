# Chatodon - Docker deployment configuration
# Copy this file to .env and fill in the values

# Your domain name
DOMAIN=example.com

# Host interface Traefik binds to.
# Use 0.0.0.0 to listen on all interfaces (public server),
# or 127.0.0.1 to expose only on localhost (e.g. behind another proxy).
TRAEFIK_HOST=0.0.0.0

# External HTTP port
HTTP_PORT=80

# External HTTPS port (only used with docker-compose.ssl.yml)
HTTPS_PORT=443

# Email for Let's Encrypt certificate notifications (only used with docker-compose.ssl.yml)
ACME_EMAIL=admin@example.com

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_LANGUAGE_CODE=en-us
DJANGO_TIME_ZONE=UTC

# PostgreSQL
POSTGRES_DB=chatodon
POSTGRES_USER=chatodon
POSTGRES_PASSWORD=change-me-to-a-secure-password

# JWT
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
